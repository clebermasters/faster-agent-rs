# ==============================================================================
# Skill Agent - Environment Configuration
# ==============================================================================

# LLM Configuration
# Providers: minimax | ollama | bedrock
LLM_PROVIDER=minimax
# The default model to use for agent interactions
DEFAULT_MODEL=MiniMax-Text-01
# Maximum number of consecutive tool calls the agent can make (-1 for unlimited)
MAX_ITERATIONS=10

# MiniMax Configuration
# Required when using minimax provider
MINIMAX_API_KEY=your-minimax-api-key-here
# Optional MiniMax API URL
# MINIMAX_URL=https://api.minimax.io

# Ollama Configuration
# Required for generating vector embeddings locally
OLLAMA_URL=http://localhost:11434
# The model to use for vector embeddings
EMBEDDING_MODEL=nomic-embed-text

# ==============================================================================
# AWS Bedrock Configuration  (LLM_PROVIDER=bedrock)
# ==============================================================================
#
# Supported model IDs:
#   Claude 3.5 Sonnet v2 : anthropic.claude-3-5-sonnet-20241022-v2:0
#   Claude 3.5 Haiku     : anthropic.claude-3-5-haiku-20241022-v1:0
#   Amazon Nova 2 Lite   : amazon.nova-2-lite-v1:0   (full tools + system prompt)
#   MiniMax M2.1         : minimax.minimax-m2.1       (1M ctx, 8K out)
#   ZAI GLM-4.7          : zai.glm-4.7               (128K ctx, 4K out)
#
# For MiniMax and ZAI models, prefer BEDROCK_AUTH=api-key (mantle endpoint)
# so that system prompts and tool calling work in standard OpenAI format.
#
# LLM_PROVIDER=bedrock
# DEFAULT_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
# BEDROCK_REGION=us-east-1

# ------------------------------------------------------------------------------
# Auth method — choose ONE of: default | static | sts-token | sts-role | api-key
# ------------------------------------------------------------------------------
# BEDROCK_AUTH=default

# default: uses ~/.aws/credentials, env vars, or EC2/ECS/Lambda instance profile
# No extra variables needed.

# static: long-term IAM access key + secret
# BEDROCK_AUTH=static
# BEDROCK_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# BEDROCK_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# sts-token: pre-obtained short-lived STS session credentials
# BEDROCK_AUTH=sts-token
# BEDROCK_ACCESS_KEY_ID=ASIAIOSFODNN7EXAMPLE
# BEDROCK_SECRET_ACCESS_KEY=...
# BEDROCK_SESSION_TOKEN=AQoDYXdz...

# sts-role: call STS AssumeRole at startup (source creds from default chain)
# BEDROCK_AUTH=sts-role
# BEDROCK_ROLE_ARN=arn:aws:iam::123456789012:role/BedrockRole
# BEDROCK_ROLE_SESSION_NAME=skill-agent
# BEDROCK_EXTERNAL_ID=optional-for-cross-account

# api-key: Bedrock API Key for the bedrock-mantle OpenAI-compatible endpoint
#          Recommended for MiniMax M2.1 and ZAI GLM-4.7
# BEDROCK_AUTH=api-key
# BEDROCK_API_KEY=<your-bedrock-api-key>
